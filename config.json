{
  "vaultPath": "./vault",
  "transcribe": {
    "engine": "mlx-whisper",
    "model": "mlx-community/whisper-large-v3-mlx",
    "language": "zh",
    "fallbackEngine": "openai-whisper",
    "fallbackModel": "medium"
  },
  "ocr": {
    "engine": "ocrmac",
    "languages": ["zh-Hant", "en-US"],
    "visionModel": "claude"
  },
  "publish": {
    "docx": "pandoc",
    "docxFallback": "officecli"
  },
  "diarize": {
    "enabled": false,
    "engine": "senko",
    "venv": "~/.meeting-harness/senko-venv",
    "note": "可選、預設關閉；只對標記為多講者的場次開（在該場 錄音/ 放一個 .diarize 空檔，或用 meeting.sh --diarize）。輸出 錄音/transcript.speakers.md。可放 錄音/speakers.map.json 把 SPEAKER_00 改成真名。"
  },
  "sourceLayout": {
    "audioGlob": "錄音/*.m4a",
    "liveTranscript": "錄音/轉文字.txt",
    "photosDir": "照片",
    "transcriptOut": "錄音/transcript.md",
    "slidesOut": "照片/slides.md",
    "summaryOut": "summary.md",
    "docxDir": "exports",
    "stateFile": ".pipeline-state.json"
  },
  "guardrails": {
    "localFirst": true,
    "cloudVisionOnlyForFlaggedSlides": true,
    "requireVerifierPassBeforePublish": true
  }
}
